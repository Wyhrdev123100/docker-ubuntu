FROM --platform=linux/amd64 ubuntu:22.04

# Thiết lập không tương tác để tránh lỗi khi build
ENV DEBIAN_FRONTEND=noninteractive

# Cập nhật và cài đặt các công cụ cơ bản + ttyd (Terminal qua Web)
RUN apt update && apt install -y --no-install-recommends \
    sudo \
    vim \
    curl \
    wget \
    git \
    net-tools \
    ca-certificates \
    build-essential \
    bash-completion \
    ttyd \
    && apt clean \
    && rm -rf /var/lib/apt/lists/*

# Thiết lập thư mục làm việc là /root
WORKDIR /root

# Tùy chỉnh dòng lệnh PS1 cho giống Termux
RUN echo "export PS1='\[\e[32m\][Termux-Railway]\[\e[m\] \[\e[34m\]\w\[\e[m\] \$ '" >> /root/.bashrc

# Railway sẽ cung cấp một cổng ngẫu nhiên qua biến môi trường PORT
# Chúng ta sẽ chạy ttyd trên cổng đó để có thể truy cập từ trình duyệt
CMD ttyd -p $PORT -a bash
